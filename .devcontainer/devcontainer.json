{
	"name": "SQLite Classroom",

	"image": "mcr.microsoft.com/devcontainers/base:bookworm",

	"postCreateCommand": "sudo apt update && sudo apt install -y sqlite3",

	"customizations": {
		"vscode": {
			"extensions": [
				"alexcvzz.vscode-sqlite"
			],

			"settings": {
				"editor.formatOnSave": true,

				"github.copilot.enable": {
					"*": false
				}
			}
		}
	},

	"remoteUser": "vscode"
}